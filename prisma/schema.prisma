// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

model User {
  id           String   @id @default(uuid())
  name         String?
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions              UserSession[]
  landingPages          LandingPage[]
  projects              Project[]
  tasks                 Task[]
  taskTemplates         TaskTemplate[]
  timeEntries           TimeEntry[]
  notes                 Note[]
  noteFolders           NoteFolder[]
  noteAttachments       NoteAttachment[]
  dailyChecklistItems   DailyChecklistItem[]
  dailyChecklistEntries DailyChecklistEntry[]
  activityLogs          TaskActivityLog[]
}

model UserSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LandingPage {
  id             String   @id @default(uuid())
  userId         String
  name           String
  slug           String   @unique
  description    String
  avatarImageUrl String
  coverImageUrl  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactInfo        ContactInfo?
  portfolioContent   PortfolioContent?
  projects           Project[]
  pageViews          PageView[]
  socialInteractions SocialInteraction[]

  @@index([userId])
  @@index([userId, updatedAt])
}

model PortfolioContent {
  id            String   @id @default(uuid())
  landingpageId String   @unique
  hero          Json?
  about         Json?
  services      Json?
  process       Json?
  contact       Json?
  projects      Json?
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  landingpage LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
}

model ContactInfo {
  id            String  @id @default(uuid())
  email         String
  phone         String?
  whatsappLink  String?
  instagramLink String?
  facebookLink  String?
  linkedinLink  String?

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String      @unique
}

// Adicione o relacionamento no modelo Project existente
model Project {
  id              String   @id @default(uuid())
  userId          String
  title           String
  category        String
  description     String
  fullDescription String
  image           String
  technologies    String[]
  liveUrl         String?
  githubUrl       String?
  featured        Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("completed")
  accentColor     String?  @default("from-gray-500/20 to-gray-600/20")
  position        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String

  // Adicione esta relação para tasks
  tasks    Task[] // Relacionamento com tasks
  features Feature[]
  sprints  Sprint[]
  notes    Note[]

  @@index([userId])
  @@index([userId, position])
  @@index([userId, isActive])
}

// Modelo para administrador
model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String // Armazenaremos hash da senha
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Adicione estes modelos ao seu schema.prisma

// Modelo para rastreamento de visualizações
model PageView {
  id        String   @id @default(uuid())
  page      String // Ex: 'home', 'projects', 'about'
  path      String // URL completa
  ip        String?
  userAgent String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String
}

// Modelo para interações sociais
model SocialInteraction {
  id        String   @id @default(uuid())
  platform  String // 'linkedin', 'github', 'instagram', etc
  type      String // 'follow', 'like', 'comment', 'share'
  content   String? // Conteúdo do comentário, etc
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String

  @@unique([platform, type, landingpageId, createdAt])
}

// Modelo para Features
model Feature {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("planning") // planning, in-progress, completed, cancelled
  priority    String   @default("medium") // low, medium, high, urgent
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// Modelo para Sprints
model Sprint {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("planning") // planning, active, completed
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// Template de Tarefas
model TaskTemplate {
  id             String   @id @default(uuid())
  userId         String
  name           String
  description    String?
  status         String   @default("pending")
  priority       String   @default("medium")
  estimatedHours Float?   @default(0)
  tags           String[] // Array de tags
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

// Time Tracking
model TimeEntry {
  id          String   @id @default(uuid())
  taskId      String
  userId      String
  description String?
  hours       Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, taskId])
  @@index([userId, date])
}

// Task Dependency
model TaskDependency {
  id             String @id @default(uuid())
  taskId         String
  dependsOnId    String
  dependencyType String @default("blocks") // blocks, relates_to

  task      Task @relation("TaskDependencies", fields: [taskId], references: [id])
  dependsOn Task @relation("DependsOnTasks", fields: [dependsOnId], references: [id])

  @@unique([taskId, dependsOnId])
}

model Task {
  id             String    @id @default(uuid())
  userId         String
  title          String
  description    String?
  status         String    @default("pending")
  priority       String    @default("medium")
  dueDate        DateTime?
  estimatedHours Float?    @default(0)
  actualHours    Float?    @default(0)
  position       Int       @default(0)

  tags          String[]  @default([])
  recurrence    String?
  recurrenceEnd DateTime?
  completedAt   DateTime?
  noteTaskKey   String?

  // Novas relações
  templateId   String?
  template     TaskTemplate?     @relation(fields: [templateId], references: [id])
  timeEntries  TimeEntry[]
  dependencies TaskDependency[]  @relation("TaskDependencies")
  dependedOnBy TaskDependency[]  @relation("DependsOnTasks")
  activityLogs TaskActivityLog[]

  // Relacionamentos
  projectId String?
  featureId String?
  sprintId  String?
  parentId  String?
  noteId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  feature  Feature? @relation(fields: [featureId], references: [id], onDelete: SetNull)
  sprint   Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  note     Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  parent   Task?    @relation("TaskToSubtask", fields: [parentId], references: [id])
  subtasks Task[]   @relation("TaskToSubtask")

  @@unique([noteId, noteTaskKey])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, projectId])
  @@index([userId, sprintId])
  @@index([userId, noteId])
  @@index([userId, updatedAt])
}

model DailyChecklistItem {
  id          String   @id @default(uuid())
  userId      String
  slug        String
  title       String
  description String
  period      String
  timeRange   String
  startTime   String?
  endTime     String?
  position    Int      @default(0)
  active      Boolean  @default(true)
  isSacred    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      DailyChecklistEntry[]
  activityLogs TaskActivityLog[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([userId, period])
  @@index([userId, position])
}

model DailyChecklistEntry {
  id          String    @id @default(uuid())
  userId      String
  itemId      String
  date        DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  item DailyChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId, date])
  @@index([userId])
  @@index([userId, date])
}

model TaskActivityLog {
  id                   String   @id @default(uuid())
  userId               String
  taskId               String?
  dailyChecklistItemId String?
  type                 String
  message              String
  metadata             Json?
  createdAt            DateTime @default(now())

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  task               Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  dailyChecklistItem DailyChecklistItem? @relation(fields: [dailyChecklistItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, taskId])
  @@index([userId, dailyChecklistItemId])
  @@index([userId, type])
}

enum NoteVisibility {
  PUBLIC
  PRIVATE
}

enum NoteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Note {
  id                String         @id @default(uuid())
  userId            String
  title             String
  slug              String
  content           String         @db.Text
  excerpt           String?
  visibility        NoteVisibility @default(PRIVATE)
  status            NoteStatus     @default(DRAFT)
  statusBeforeTrash NoteStatus?
  trashedAt         DateTime?

  isFavorite Boolean @default(false)
  viewCount  Int     @default(0)

  fileName   String?
  filePath   String?
  folderPath String?
  folderName String?
  folderId   String?
  extension  String?
  importedAt DateTime?
  position   Int       @default(0)

  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folder  NoteFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  tags     NoteTag[]
  outgoing NoteLink[] @relation("SourceLinks")
  incoming NoteLink[] @relation("TargetLinks")
  tasks    Task[]

  @@unique([userId, slug])
  @@unique([userId, filePath])
  @@index([userId])
  @@index([userId, visibility])
  @@index([userId, status])
  @@index([userId, trashedAt])
  @@index([userId, projectId])
  @@index([userId, folderPath])
  @@index([userId, folderId])
  @@index([userId, position])
  @@index([userId, updatedAt])
}

model NoteFolder {
  id                  String    @id @default(uuid())
  userId              String
  name                String
  path                String
  parentId            String?
  position            Int       @default(0)
  deletedAt           DateTime?
  trashedAt           DateTime?
  pathBeforeTrash     String?
  parentIdBeforeTrash String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   NoteFolder?  @relation("NoteFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children NoteFolder[] @relation("NoteFolderTree")
  notes    Note[]

  @@unique([userId, path])
  @@index([userId])
  @@index([userId, parentId])
  @@index([userId, position])
  @@index([userId, deletedAt])
  @@index([userId, trashedAt])
}

model NoteAttachment {
  id         String   @id @default(uuid())
  userId     String
  fileName   String
  filePath   String
  folderPath String?
  folderName String?
  extension  String?
  mimeType   String?
  size       Int?
  dataUrl    String?  @db.Text
  importedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, filePath])
  @@index([userId])
  @@index([userId, folderPath])
  @@index([userId, fileName])
}

model NoteTag {
  id        String   @id @default(uuid())
  noteId    String
  name      String
  slug      String
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, slug])
  @@index([slug])
  @@index([name])
}

model NoteLink {
  id           String   @id @default(uuid())
  sourceNoteId String
  targetNoteId String?
  targetSlug   String
  targetTitle  String
  alias        String?
  occurrences  Int      @default(1)
  targetExists Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sourceNote Note  @relation("SourceLinks", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote Note? @relation("TargetLinks", fields: [targetNoteId], references: [id], onDelete: SetNull)

  @@unique([sourceNoteId, targetSlug])
  @@index([targetNoteId])
  @@index([targetSlug])
  @@index([targetExists])
}
