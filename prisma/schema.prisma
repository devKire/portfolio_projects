// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LandingPage {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String
  avatarImageUrl String
  coverImageUrl  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contactInfo        ContactInfo?
  portfolioContent   PortfolioContent?
  projects           Project[]
  pageViews          PageView[]
  socialInteractions SocialInteraction[]
}

model PortfolioContent {
  id            String   @id @default(uuid())
  landingpageId String   @unique
  hero          Json?
  about         Json?
  services      Json?
  process       Json?
  contact       Json?
  projects      Json?
  settings      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  landingpage LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
}

model ContactInfo {
  id            String  @id @default(uuid())
  email         String
  phone         String?
  whatsappLink  String?
  instagramLink String?
  facebookLink  String?
  linkedinLink  String?

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String      @unique
}

// Adicione o relacionamento no modelo Project existente
model Project {
  id              String   @id @default(uuid())
  title           String
  category        String
  description     String
  fullDescription String
  image           String
  technologies    String[]
  liveUrl         String?
  githubUrl       String?
  featured        Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("completed")
  accentColor     String?  @default("from-gray-500/20 to-gray-600/20")
  position        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String

  // Adicione esta relação para tasks
  tasks    Task[] // Relacionamento com tasks
  features Feature[]
  sprints  Sprint[]
}

// Modelo para administrador
model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String // Armazenaremos hash da senha
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Adicione estes modelos ao seu schema.prisma

// Modelo para rastreamento de visualizações
model PageView {
  id        String   @id @default(uuid())
  page      String // Ex: 'home', 'projects', 'about'
  path      String // URL completa
  ip        String?
  userAgent String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String
}

// Modelo para interações sociais
model SocialInteraction {
  id        String   @id @default(uuid())
  platform  String // 'linkedin', 'github', 'instagram', etc
  type      String // 'follow', 'like', 'comment', 'share'
  content   String? // Conteúdo do comentário, etc
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  landingpage   LandingPage @relation(fields: [landingpageId], references: [id], onDelete: Cascade)
  landingpageId String

  @@unique([platform, type, landingpageId, createdAt])
}

// Modelo para Features
model Feature {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("planning") // planning, in-progress, completed, cancelled
  priority    String   @default("medium") // low, medium, high, urgent
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// Modelo para Sprints
model Sprint {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("planning") // planning, active, completed
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// Template de Tarefas
model TaskTemplate {
  id             String   @id @default(uuid())
  name           String
  description    String?
  status         String   @default("pending")
  priority       String   @default("medium")
  estimatedHours Float?   @default(0)
  tags           String[] // Array de tags
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks Task[]
}

// Time Tracking
model TimeEntry {
  id          String   @id @default(uuid())
  taskId      String
  userId      String?
  description String?
  hours       Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// Task Dependency
model TaskDependency {
  id             String @id @default(uuid())
  taskId         String
  dependsOnId    String
  dependencyType String @default("blocks") // blocks, relates_to

  task      Task @relation("TaskDependencies", fields: [taskId], references: [id])
  dependsOn Task @relation("DependsOnTasks", fields: [dependsOnId], references: [id])

  @@unique([taskId, dependsOnId])
}

model Task {
  id             String    @id @default(uuid())
  title          String
  description    String?
  status         String    @default("pending")
  priority       String    @default("medium")
  dueDate        DateTime?
  estimatedHours Float?    @default(0)
  actualHours    Float?    @default(0)
  position       Int       @default(0)

  tags          String[]  @default([])
  recurrence    String?
  recurrenceEnd DateTime?
  completedAt   DateTime?

  // Novas relações
  templateId   String?
  template     TaskTemplate?     @relation(fields: [templateId], references: [id])
  timeEntries  TimeEntry[]
  dependencies TaskDependency[]  @relation("TaskDependencies")
  dependedOnBy TaskDependency[]  @relation("DependsOnTasks")
  activityLogs TaskActivityLog[]

  // Relacionamentos
  projectId String?
  featureId String?
  sprintId  String?
  parentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  feature  Feature? @relation(fields: [featureId], references: [id], onDelete: SetNull)
  sprint   Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent   Task?    @relation("TaskToSubtask", fields: [parentId], references: [id])
  subtasks Task[]   @relation("TaskToSubtask")

  @@index([status])
  @@index([projectId])
  @@index([sprintId])
}

model DailyChecklistItem {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  period      String
  timeRange   String
  startTime   String?
  endTime     String?
  position    Int      @default(0)
  active      Boolean  @default(true)
  isSacred    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries      DailyChecklistEntry[]
  activityLogs TaskActivityLog[]

  @@index([period])
  @@index([position])
}

model DailyChecklistEntry {
  id          String    @id @default(uuid())
  itemId      String
  date        DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item DailyChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, date])
  @@index([date])
}

model TaskActivityLog {
  id                   String   @id @default(uuid())
  taskId               String?
  dailyChecklistItemId String?
  type                 String
  message              String
  metadata             Json?
  createdAt            DateTime @default(now())

  task               Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  dailyChecklistItem DailyChecklistItem? @relation(fields: [dailyChecklistItemId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([taskId])
  @@index([dailyChecklistItemId])
  @@index([type])
}
